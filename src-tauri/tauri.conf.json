{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Avatar Changer",
  "version": "0.1.6",
  "identifier": "com.gifum.avatarchanger",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Avatar Changer",
        "width": 1440,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://api.vrchat.cloud; connect-src 'self' ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420 https://api.vrchat.cloud",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "C:/Users/gifum/AppData/Local/AvatarChanger/cache/thumbnails/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
